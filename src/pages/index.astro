<script is:inline>
    const form = document.getElementById("registration-form-element");
    const submitButton = document.getElementById("submit-button");
    const formStatus = document.getElementById("form-status");

    // BURAYA Google Apps Script Web App URL'sinizi yapıştırın
    const SCRIPT_URL =
        "https://script.google.com/macros/s/AKfycbw2gD0X2fAFLCT9yuQeJH6fm3PDJ-PvKl8dSNf1Z4bihghdYD-HsabB2asZfQ3aDrdWuQ/exec";

    form.addEventListener("submit", (e) => {
        e.preventDefault();

        submitButton.disabled = true;
        submitButton.innerHTML =
            '<span class="flex items-center justify-center gap-2"><svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Gönderiliyor...</span>';

        formStatus.classList.remove("hidden", "text-red-500", "text-green-600");
        formStatus.classList.add("text-slate-500");
        formStatus.textContent =
            "Bilgileriniz kaydediliyor, lütfen bekleyin...";

        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => (data[key] = value));
        data["timestamp"] = new Date().toLocaleString("tr-TR");

        fetch(SCRIPT_URL, {
            method: "POST",
            mode: "no-cors", // Google Apps Script için no-cors gerekli olabilir
            body: JSON.stringify(data),
            headers: {
                "Content-Type": "application/json",
            },
        })
            .then(() => {
                formStatus.textContent =
                    "Kaydınız başarıyla alındı! Sizinle en kısa sürede iletişime geçeceğiz.";
                formStatus.classList.replace(
                    "text-slate-500",
                    "text-green-600",
                );
                form.reset();
                submitButton.disabled = false;
                submitButton.textContent = "Ücretsiz Kayıt Ol";

                // 3 saniye sonra mesajı gizle
                setTimeout(() => {
                    formStatus.classList.add("hidden");
                }, 5000);
            })
            .catch((error) => {
                console.error("Hata!", error.message);
                formStatus.textContent =
                    "Bir hata oluştu. Lütfen tekrar deneyin.";
                formStatus.classList.replace("text-slate-500", "text-red-500");
                submitButton.disabled = false;
                submitButton.textContent = "Tekrar Dene";
            });
    });
</script>
