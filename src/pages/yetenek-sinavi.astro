---
import "../styles/global.css";
---

<!doctype html>
<html lang="tr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>
            Çocuğunun Yeteneğini Keşfet Sınavı | Zübeyde Hanım Eğitim Kurumları
        </title>
        <meta
            name="description"
            content="Zübeyde Hanım Eğitim Kurumları Yetenek Keşif Sınavı ile çocuğunuzun potansiyelini ortaya çıkarın. Ücretsiz kayıt olun."
        />

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700;800&display=swap"
            rel="stylesheet"
        />

        <style>
            :root {
                font-family: "Inter", sans-serif;
            }
            h1,
            h2,
            h3,
            .font-display {
                font-family: "Outfit", sans-serif;
            }
            .bg-dots {
                background-image: radial-gradient(
                    #1e3a8a 0.5px,
                    transparent 0.5px
                );
                background-size: 24px 24px;
                opacity: 0.05;
            }
        </style>
    </head>
    <body class="bg-slate-50">
        <!-- 1. Header (Minimalist + Socials) -->
        <header
            class="py-4 md:py-6 bg-white border-b border-slate-100 sticky top-0 z-50"
        >
            <div
                class="max-w-7xl mx-auto px-2 md:px-4 flex justify-between items-center"
            >
                <a href="/" class="flex items-center shrink-0">
                    <img
                        src="/images/logo.png"
                        alt="Zübeyde Hanım Eğitim Kurumları Logo"
                        class="h-10 md:h-16 w-auto"
                    />
                </a>

                <div class="flex items-center gap-2 md:gap-6">
                    <!-- Contact Info -->
                    <div
                        class="flex flex-col md:flex-row items-end md:items-center gap-1 md:gap-4 text-[10px] md:text-sm font-semibold text-slate-600"
                    >
                        <a
                            href="tel:02323321881"
                            class="flex items-center gap-1.5 hover:text-blue-900 transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="w-3 h-3 md:w-4 md:h-4 text-amber-500"
                                ><path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                                ></path></svg
                            >
                            0 232 332 1881
                        </a>
                        <a
                            href="mailto:info@zubeydehanim.com.tr"
                            class="flex items-center gap-1.5 hover:text-blue-900 transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="w-3 h-3 md:w-4 md:h-4 text-amber-500"
                                ><rect width="20" height="16" x="2" y="4" rx="2"
                                ></rect><path
                                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                ></path></svg
                            >
                            info@zubeydehanim.com.tr
                        </a>
                    </div>

                    <!-- Socials -->
                    <div class="flex items-center gap-2 md:gap-4">
                        <a
                            href="https://www.instagram.com/zubeydehanimegitimkurumlari/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-900 hover:text-amber-500 transition-colors bg-slate-50 p-1.5 md:p-2 rounded-full hover:bg-amber-50"
                            aria-label="Instagram"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="lucide lucide-instagram w-4 h-4 md:w-5 md:h-5"
                                ><rect
                                    width="20"
                                    height="20"
                                    x="2"
                                    y="2"
                                    rx="5"
                                    ry="5"></rect><path
                                    d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                                ></path><line
                                    x1="17.5"
                                    x2="17.51"
                                    y1="6.5"
                                    y2="6.5"></line></svg
                            >
                        </a>
                        <a
                            href="https://www.facebook.com/zubeydehanimegitimkurumlari"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-900 hover:text-amber-500 transition-colors bg-slate-50 p-1.5 md:p-2 rounded-full hover:bg-amber-50"
                            aria-label="Facebook"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="lucide lucide-facebook w-4 h-4 md:w-5 md:h-5"
                                ><path
                                    d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                                ></path></svg
                            >
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <main>
            <!-- 2. The Hero Section (Split Layout) -->
            <section
                class="relative overflow-hidden pt-12 pb-24 lg:pt-20 lg:pb-32 bg-white"
            >
                <div class="absolute inset-0 bg-dots"></div>
                <div
                    class="absolute inset-0 bg-gradient-to-b from-blue-50/50 to-transparent"
                >
                </div>

                <div class="max-w-7xl mx-auto px-4 relative z-10">
                    <div
                        class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center"
                    >
                        <!-- Left Column: The Pitch -->
                        <div class="relative z-10">
                            <span
                                class="inline-block px-4 py-1.5 bg-amber-100 text-amber-700 text-sm font-bold uppercase tracking-widest rounded-full mb-6"
                            >
                                11 Nisan Yetenek Keşfi Sınavı
                            </span>
                            <h1
                                class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-blue-900 leading-[1.2] mb-6 tracking-tight"
                            >
                                Çocuğunuzun Yeteneğini <br />
                                <span class="text-amber-500"
                                    >Keşfetmeye Hazır Mısınız?</span
                                >
                            </h1>
                            <p
                                class="text-lg text-slate-600 mb-8 max-w-xl leading-relaxed"
                            >
                                Zübeyde Hanım Okulları Buca ve Çiçekliköy
                                Kampüsleri’nde düzenlenen Yetenek Keşfi
                                Değerlendirmesi ile çocuğunuzun güçlü yönlerini
                                alanında uzman öğretmenlerle birlikte keşfedin,
                                hem de sadece 10 dakikada!
                            </p>

                            <div class="relative max-w-lg mx-auto lg:mx-0">
                                <img
                                    src="/images/banner.png"
                                    alt="Çocuğunun yeteneğini keşfet"
                                    class="w-full h-auto rounded-[2.5rem] shadow-2xl border-4 border-white"
                                />
                                <div
                                    class="absolute -bottom-4 -right-4 w-24 h-24 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold text-center leading-tight shadow-lg transform rotate-12"
                                >
                                    Ücretsiz<br />Kayıt
                                </div>
                            </div>
                        </div>

                        <!-- Right Column: Registration Form -->
                        <div id="registration-form">
                            <div
                                class="bg-white p-8 md:p-10 rounded-[2.5rem] shadow-2xl shadow-blue-900/10 border-t-4 border-blue-900 relative"
                            >
                                <div class="mb-8">
                                    <h2
                                        class="text-2xl font-bold text-blue-900 mb-2"
                                    >
                                        Hemen Ön Kayıt Oluşturun
                                    </h2>
                                    <p class="text-slate-500">
                                        Sadece 1 dakikada kaydınızı tamamlayın.
                                    </p>
                                </div>

                                <form class="space-y-4">
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1"
                                            >Veli Adı Soyadı</label
                                        >
                                        <input
                                            type="text"
                                            placeholder="Adınız ve soyadınız"
                                            class="input-field"
                                            required
                                        />
                                    </div>

                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1"
                                            >Öğrenci Adı Soyadı</label
                                        >
                                        <input
                                            type="text"
                                            placeholder="Öğrencinin adı ve soyadı"
                                            class="input-field"
                                            required
                                        />
                                    </div>

                                    <div class="grid grid-cols-2 gap-4">
                                        <div>
                                            <label
                                                class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1"
                                                >Öğrenci Sınıfı</label
                                            >
                                            <select
                                                class="input-field appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2020%2020%22%3E%3Cpath%20stroke%3D%22%236b7280%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%221.5%22%20d%3D%22m6%208%204%204%204-4%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25rem_1.25rem] bg-[right_1rem_center] bg-no-repeat"
                                                required
                                            >
                                                <option value="">Seçiniz</option
                                                >
                                                <option>Anasınıfı</option>
                                                <option>1. Sınıf</option>
                                                <option>2. Sınıf</option>
                                                <option>3. Sınıf</option>
                                                <option>4. Sınıf</option>
                                                <option>5. Sınıf</option>
                                                <option>6. Sınıf</option>
                                                <option>7. Sınıf</option>
                                                <option>8. Sınıf</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label
                                                class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1"
                                                >Telefon Numarası</label
                                            >
                                            <input
                                                type="tel"
                                                placeholder="05XX XXX XX XX"
                                                class="input-field"
                                                required
                                            />
                                        </div>
                                    </div>

                                    <button
                                        type="submit"
                                        class="btn-primary w-full mt-2"
                                    >
                                        Ücretsiz Kayıt Ol
                                    </button>

                                    <p
                                        class="text-center text-[10px] text-slate-400 mt-4 leading-tight"
                                    >
                                        Kişisel verileriniz KVKK kapsamında
                                        korunmaktadır. Formu doldurarak iletişim
                                        bilgilerinizin bilgilendirme amacıyla
                                        kullanılmasını kabul etmiş olursunuz.
                                    </p>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 3. Quick Info Strip -->
            <div class="max-w-5xl mx-auto px-4 -mt-10 relative z-20">
                <div
                    class="bg-white rounded-3xl shadow-xl border border-slate-100 p-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center divide-x-0 md:divide-x divide-slate-100"
                >
                    <div class="px-2">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-amber-500 mx-auto mb-3"
                            ><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path
                                d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path
                                d="M4 22h16"></path><path
                                d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
                            ></path><path
                                d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
                            ></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"
                            ></path></svg
                        >
                        <p
                            class="text-[10px] text-slate-500 uppercase font-bold tracking-wider mb-1"
                        >
                            Sınav Adı
                        </p>
                        <p
                            class="font-bold text-blue-900 border-b-2 border-amber-400 inline-block pb-1"
                        >
                            Yeteneği Keşfet
                        </p>
                    </div>
                    <div class="px-2 border-l border-slate-100 md:border-l-0">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-amber-500 mx-auto mb-3"
                            ><rect
                                width="18"
                                height="18"
                                x="3"
                                y="4"
                                rx="2"
                                ry="2"></rect><line
                                x1="16"
                                x2="16"
                                y1="2"
                                y2="6"></line><line x1="8" x2="8" y1="2" y2="6"
                            ></line><line x1="3" x2="21" y1="10" y2="10"
                            ></line></svg
                        >
                        <p
                            class="text-[10px] text-slate-500 uppercase font-bold tracking-wider mb-1"
                        >
                            Tarih
                        </p>
                        <p class="font-bold text-blue-900 text-sm">11 Nisan</p>
                    </div>
                    <div class="px-2">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-amber-500 mx-auto mb-3"
                            ><circle cx="12" cy="12" r="10"></circle><polyline
                                points="12 6 12 12 16 14"></polyline></svg
                        >
                        <p
                            class="text-[10px] text-slate-500 uppercase font-bold tracking-wider mb-1"
                        >
                            Süre
                        </p>
                        <p class="font-bold text-blue-900 text-sm">10 Dakika</p>
                    </div>
                    <div class="px-2 border-l border-slate-100 md:border-l-0">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-amber-500 mx-auto mb-3"
                            ><path
                                d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                            ></path><circle cx="12" cy="10" r="3"></circle></svg
                        >
                        <p
                            class="text-[10px] text-slate-500 uppercase font-bold tracking-wider mb-1"
                        >
                            Yer
                        </p>
                        <p class="font-bold text-blue-900 text-xs">
                            Zübeyde Hanım Çiçekliköy<br />ve Buca Kampüsleri
                        </p>
                    </div>
                </div>
            </div>

            <!-- 4. Info Section: "Bu Sınav Neden Önemli?" -->
            <section class="py-24 bg-slate-50 relative overflow-hidden">
                <div class="max-w-7xl mx-auto px-4 relative z-10">
                    <div class="text-center mb-16">
                        <h2
                            class="text-3xl md:text-5xl font-extrabold text-blue-900 mb-4"
                        >
                            Bu Sınav Neden Önemli?
                        </h2>
                        <div class="w-24 h-2 bg-amber-500 mx-auto rounded-full">
                        </div>
                    </div>

                    <div class="space-y-16">
                        <!-- Card 1: Image Left -->
                        <div
                            class="grid md:grid-cols-12 gap-10 items-stretch bg-white p-6 md:p-10 rounded-[2.5rem] shadow-2xl shadow-blue-900/5 border border-slate-100 overflow-hidden"
                        >
                            <div class="md:col-span-5 h-full relative">
                                <img
                                    src="/images/kutucuk 1.jpg"
                                    alt="Yetenek Keşfi Nedir?"
                                    class="w-full h-full object-cover rounded-2xl shadow-md border border-slate-200"
                                />
                            </div>
                            <div
                                class="md:col-span-7 flex flex-col justify-center py-4 pr-4 text-slate-700"
                            >
                                <h3
                                    class="text-3xl font-bold text-blue-900 mb-6"
                                >
                                    Yetenek Keşfi Nedir?
                                </h3>
                                <p class="text-lg leading-relaxed mb-4">
                                    Her çocuk farklı bir potansiyele sahiptir.
                                    Yetenek keşfi değerlendirmesi, çocukların
                                    doğal eğilimlerini ve güçlü yönlerini erken
                                    yaşta fark edebilmek için hazırlanan özel
                                    bir değerlendirme sürecidir.
                                </p>
                                <p class="text-lg leading-relaxed mb-4">
                                    Zübeyde Hanım Okulları’nda uygulanan bu
                                    süreçte öğrenciler;
                                </p>
                                <ul
                                    class="list-disc pl-6 space-y-2 text-lg mb-4 font-medium"
                                >
                                    <li>Müzik, ritm ve algı</li>
                                    <li>Spor</li>
                                    <li>Robotik ve teknoloji</li>
                                    <li>Matematiksel düşünme</li>
                                    <li>Resim</li>
                                </ul>
                                <p class="text-lg leading-relaxed">
                                    gibi farklı alanlarda alanında uzman
                                    öğretmenler tarafından gözlemlenir ve
                                    değerlendirilir. Bu sayede çocuğunuzun hangi
                                    alanlara daha yatkın olduğu hakkında önemli
                                    ipuçları elde edilir.
                                </p>
                            </div>
                        </div>

                        <!-- Card 2: Image Right (ZAG) -->
                        <div
                            class="grid md:grid-cols-12 gap-10 items-stretch bg-white p-6 md:p-10 rounded-[2.5rem] shadow-2xl shadow-blue-900/5 border border-slate-100 overflow-hidden"
                        >
                            <div
                                class="md:col-span-7 md:order-1 order-2 flex flex-col justify-center py-4 pl-4 text-slate-700"
                            >
                                <h3
                                    class="text-3xl font-bold text-blue-900 mb-6"
                                >
                                    Yetenek Keşfi Sürecinde Neler Yapılıyor?
                                </h3>
                                <p class="text-lg leading-relaxed mb-4">
                                    Değerlendirme sürecinde öğrenciler farklı
                                    istasyonlarda kısa ve eğlenceli uygulamalara
                                    katılır.
                                </p>
                                <p class="text-lg leading-relaxed mb-4">
                                    Bu uygulamalar sırasında öğretmenler;
                                </p>
                                <ul class="space-y-2 text-lg mb-4 font-medium">
                                    <li class="flex items-start gap-2">
                                        <span class="text-amber-500 font-bold"
                                            >✔</span
                                        > Ritm ve müzik algısını
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-amber-500 font-bold"
                                            >✔</span
                                        > Analitik ve matematiksel düşünme becerilerini
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-amber-500 font-bold"
                                            >✔</span
                                        > Motor becerilerini ve spor yatkınlığını
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-amber-500 font-bold"
                                            >✔</span
                                        > Problem çözme ve robotik ilgisini
                                    </li>
                                    <li class="flex items-start gap-2">
                                        <span class="text-amber-500 font-bold"
                                            >✔</span
                                        > Dikkat ve algı düzeyini
                                    </li>
                                </ul>
                                <p class="text-lg leading-relaxed">
                                    gözlemleyerek çocukların güçlü yönlerini
                                    analiz eder.
                                </p>
                            </div>
                            <div
                                class="md:col-span-5 md:order-2 order-1 h-full relative"
                            >
                                <img
                                    src="/images/kutucuk 2.jpg"
                                    alt="Yetenek Keşfi Sürecinde Neler Yapılıyor?"
                                    class="w-full h-full object-cover rounded-2xl shadow-md border border-slate-200"
                                />
                            </div>
                        </div>

                        <!-- Card 3: Image Left (Bonus - using existing image) -->
                        <div
                            class="grid md:grid-cols-12 gap-10 items-stretch bg-white p-6 md:p-10 rounded-[2.5rem] shadow-2xl shadow-blue-900/5 border border-slate-100 overflow-hidden"
                        >
                            <div class="md:col-span-5 h-full relative">
                                <img
                                    src="/images/kutucuk 3.jpg"
                                    alt="Değerlendirmeyi Kimler Yapıyor?"
                                    class="w-full h-full object-cover rounded-2xl shadow-md border border-slate-200"
                                />
                            </div>
                            <div
                                class="md:col-span-7 flex flex-col justify-center py-4 pr-4 text-slate-700"
                            >
                                <h3
                                    class="text-3xl font-bold text-blue-900 mb-6"
                                >
                                    Değerlendirmeyi Kimler Yapıyor?
                                </h3>
                                <p class="text-lg leading-relaxed mb-4">
                                    Yetenek keşfi değerlendirmesi;
                                </p>
                                <ul
                                    class="list-disc pl-6 space-y-2 text-lg mb-4 font-medium"
                                >
                                    <li>
                                        Alanında deneyimli müzik öğretmenleri
                                    </li>
                                    <li>Beden eğitimi ve spor eğitmenleri</li>
                                    <li>Robotik ve teknoloji eğitmenleri</li>
                                    <li>Matematik öğretmenleri</li>
                                </ul>
                                <p class="text-lg leading-relaxed">
                                    tarafından gerçekleştirilmektedir. Her
                                    öğrenci farklı alanlarda gözlemlenir ve
